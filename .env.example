# Copy to ~/.config/social-scan/.env (or set SOCIAL_SCAN_ENV_FILE to this path).
# Any missing credential just disables that collector; the run still succeeds.

# Required for the X collector. Needs X Basic tier or pay-per-use (the free tier
# lacks the List Tweets endpoint). The watched X List must be public.
X_BEARER_TOKEN=

# Recommended. Raises the GitHub API rate limit from 60/hr to 5000/hr.
GITHUB_TOKEN=

# Required only for the Telegram collector (from https://my.telegram.org).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
