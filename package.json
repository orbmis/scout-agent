{
  "name": "scout-agent",
  "version": "2.0.0",
  "description": "Scout — a signal-monitoring agent for agentic payments, account abstraction, and adjacent infrastructure.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "scout": "bin/scout.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "collect": "node bin/scout.mjs collect",
    "process": "node bin/scout.mjs process",
    "run": "node bin/scout.mjs run",
    "diagnose": "node bin/scout.mjs diagnose",
    "doctor": "node bin/scout.mjs doctor",
    "selftest": "node bin/scout.mjs selftest",
    "live": "node scripts/live-e2e.mjs",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
